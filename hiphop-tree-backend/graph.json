    { "id": "dj-premier",      "name": "DJ Premier",              "era": "90s",   "region": "East Coast", "label": "Gang Starr Foundation", "role": "producer", "isLegend": true, "metadata": { "personalNote": "Met Preemo at the meet-and-greet: The foundation of 90s boom-bap. His SP-1200 drum chops and jazz-loop science defined East Coast hard rap forever.", "culturalImpact": "Produced NY State of Mind Vol.2 (Nas), D'evils (Jay-Z), Ten Crack Commandments (Biggie), Mass Appeal (Gang Starr), Nas Is Like. Over 30 years of undeniable classics.", "wikidataId": "Q456097" } },
    { "id": "the-alchemist",   "name": "The Alchemist",           "era": "2000s", "region": "East Coast", "label": "ALC Records",           "role": "producer", "isLegend": true, "metadata": { "personalNote": "Met Alchemist at the meet-and-greet: A true student of the music who became the teacher — every crate he opens becomes a masterpiece.", "culturalImpact": "Produced for Eminem, Nas, Mobb Deep, Kendrick Lamar, Action Bronson, Boldy James. Set the modern boom-bap standard for a new generation.", "wikidataId": "Q1321898" } },
    { "id": "j-dilla",         "name": "J Dilla",                 "era": "2000s", "region": "Detroit",    "label": "Pay Jay Productions",   "role": "producer", "isLegend": true, "metadata": { "personalNote": "Donuts (2006), crafted from a hospital bed, changed how every producer thinks about structure, soul, and swing. Gone too soon — forever in the music.", "culturalImpact": "Produced for A Tribe Called Quest, De La Soul, Common, Busta Rhymes, Erykah Badu, Janet Jackson. The founding godfather of neo-soul rap production.", "wikidataId": "Q192024" } },
    { "id": "madlib",          "name": "Madlib",                  "era": "2000s", "region": "West Coast", "label": "Stones Throw",          "role": "producer", "isLegend": true, "metadata": { "personalNote": "Madlib is the most adventurous crate-digger in the game — no genre, tempo, or era is safe from his imagination.", "culturalImpact": "Madvillainy (2004) with MF DOOM is one of the greatest albums ever made. Also produced Freddie Gibbs's Piñata/Bandana, and Mos Def's The Ecstatic.", "wikidataId": "Q335810" } },
    { "id": "pharrell-williams","name": "Pharrell Williams",      "era": "2000s", "region": "East Coast", "label": "Star Trak / i am OTHER","role": "producer", "isLegend": true, "metadata": { "personalNote": "Pharrell's ear for melody and groove gave The Neptunes an empire that spanned rap, R&B, and pop simultaneously.", "culturalImpact": "Produced Drop It Like It's Hot (Snoop), Frontin' (Jay-Z), Alright (Kendrick), Grindin' (Clipse/Pusha T). Defined the entire 2000s pop-rap sonic palette.", "wikidataId": "Q216613" } },
    { "id": "pete-rock",       "name": "Pete Rock",               "era": "90s",   "region": "East Coast", "label": "Loud Records",          "role": "producer", "isLegend": true, "metadata": { "personalNote": "Pete Rock's horn flips and soul samples set the eternal template for what East Coast hip-hop should sound and feel like.", "culturalImpact": "Half of Pete Rock & CL Smooth. Produced for Nas, Big Pun, Heavy D, A Tribe Called Quest. His remix of EPMD's 'So Whatcha Sayin' is studied in music schools.", "wikidataId": "Q962174" } },
    { "id": "sounwave",        "name": "Sounwave",                "era": "2010s", "region": "West Coast", "label": "TDE",                   "role": "producer", "isLegend": true, "metadata": { "personalNote": "Sounwave is the sonic architect behind Kendrick's most ambitious worlds — TPAB's jazz and funk textures could not exist without his vision.", "culturalImpact": "Primary producer on GKMC, To Pimp a Butterfly, DAMN., and Mr. Morale & The Big Steppers. Shaped the entire sound of TDE across a decade.", "wikidataId": "Q7567682" } },
    { "id": "mf-doom",         "name": "MF DOOM",                 "era": "2000s", "region": "East Coast", "label": "Metal Face Records",    "role": "producer", "isLegend": true, "metadata": { "personalNote": "DOOM built a mythology around his mask, his cartoons, and his beats. Few in the history of rap have ever merged lyrical and production genius so completely.", "culturalImpact": "Operation Doomsday (1999), Mm..Food (2004), Madvillainy (2004). Influenced virtually every alternative and underground rapper of the 2010s and beyond.", "wikidataId": "Q313602" } }
